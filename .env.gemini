# ============================================================
# ELITE INTEL SYSTEM — GEMINI 2.0 FLASH CONFIG (FREE TIER)
# ============================================================

# --- GEMINI API (Free tier: 15,000 requests/day) ---
# Get key here: https://ai.google.dev/ (no credit card needed)
LLM_PROVIDER=gemini
GEMINI_API_KEY=your-free-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# --- FALLBACK (If Gemini fails, use Claude) ---
# Optional: Only needed if you want redundancy
FALLBACK_PROVIDER=claude
CLAUDE_API_KEY=your-claude-key (optional)

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- DATABASE ---
DB_PATH=./data/intel.db

# --- SYSTEM SETTINGS ---
MIN_SIGNAL_SCORE=70
MAX_BRIEF_ITEMS=7
LOG_LEVEL=INFO

# --- PERFORMANCE TUNING ---
# Gemini is fast (200-500ms), shorter timeouts are safe
LLM_TIMEOUT_SECONDS=10
RETRY_ON_FAILURE=true
MAX_RETRIES=2

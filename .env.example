# ============================================================
# ELITE INTEL AGENT — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# --- OLLAMA (Local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- TELEGRAM BOT ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID (send /start to your bot, then check logs)
TELEGRAM_CHAT_ID=your_chat_id_here

# --- WHATSAPP (Choose one method) ---
# Option A: Twilio WhatsApp
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890

# Option B: Meta WhatsApp Business API
META_WA_PHONE_NUMBER_ID=your_phone_number_id
META_WA_ACCESS_TOKEN=your_access_token
META_WA_RECIPIENT=your_recipient_phone

# --- FINANCIAL DATA APIs ---
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
POLYGON_API_KEY=your_polygon_key

# --- REDDIT API ---
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=EliteIntelAgent/1.0

# --- OPTIONAL: NEWS API ---
NEWS_API_KEY=your_news_api_key

# --- OPTIONAL: SERP API ---
SERP_API_KEY=your_serp_api_key

# --- SYSTEM SETTINGS ---
SCHEDULE_INTERVAL_MINUTES=60
MIN_SIGNAL_SCORE=65
MAX_BRIEF_ITEMS=7
SELF_LEARNING_ENABLED=true
DATA_DIR=./data
LOG_LEVEL=INFO
INTEREST_DOMAINS=ai,finance,geopolitics,biotech

# ============================================================
# ELITE INTEL AGENT — HYBRID LLM CONFIGURATION
# Local Ollama Models + Hosted LLM Fallback
# ============================================================

# --- OLLAMA (Local Models) ---
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model (Critical for speed)
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# --- LOCAL MODEL ASSIGNMENTS BY AGENT ---
# ResearchAgent: Extract data from feeds
RESEARCH_AGENT_MODEL=qwen2.5-coder:7b

# SignalAgent: Score items across 6 dimensions
SIGNAL_AGENT_MODEL=qwen3-tuned:latest

# LearningAgent: Analyze feedback patterns
LEARNING_AGENT_MODEL=qwen-tuned:latest

# --- SYNTHESIS AGENT: SPEED-PRIORITY CONFIGURATION ---
# PRIMARY: Hosted LLM for speed (under 2 seconds)
SYNTHESIS_AGENT_PRIMARY=hosted

# FALLBACK: Local model if hosted is unavailable
SYNTHESIS_AGENT_FALLBACK=qwen3:8b

# --- HOSTED LLM PROVIDERS ---
# Provider: claude, gemini, or openai
HOSTED_LLM_PROVIDER=claude

# *** CLAUDE (Recommended for this use case) ***
CLAUDE_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=2000

# *** OPENAI (Alternative) ***
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2000

# *** GEMINI (Alternative) ***
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- SPEED OPTIMIZATION FLAGS ---
# Use hosted for synthesis? (true = speed priority, false = cost priority)
USE_HOSTED_FOR_SYNTHESIS=true

# Timeout for hosted LLM (if exceeded, fall back to local)
HOSTED_LLM_TIMEOUT_SECONDS=5

# Fallback to local if hosted API rate-limited
FALLBACK_ON_RATE_LIMIT=true

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- WHATSAPP (Twilio) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+1234567890

# --- SYSTEM SETTINGS ---
SCHEDULE_INTERVAL_MINUTES=30
MIN_SIGNAL_SCORE=70
MAX_BRIEF_ITEMS=7
SELF_LEARNING_ENABLED=true
DATA_DIR=./data
LOG_LEVEL=INFO
INTEREST_DOMAINS=ai,finance,geopolitics,biotech

# --- DEBUG/MONITORING ---
# Log all LLM calls for performance tracking
LOG_LLM_LATENCY=true
# Show which model was used for each agent (hosted vs local)
LOG_MODEL_SELECTION=true
"